                        3
                    ],
                    [
                        3,
                        4
                    ],
                    [
                        4,
                        5
                    ],
                    [
                        5,
                        10
                    ]
                ]
            }
        },
        {
            "id": "Q4",
            "category": "Power flow analysis",
            "query": "Run AC power flow on the IEEE 39-bus system using the fast-decoupled method. Show the convergence result, the total active power loss, and the active power flow value of line 11.",
            "server_use": [
                "PowerFlow"
            ],
            "expected_output": {
                "converged": true,
                "total_active_power_loss_mw": 43.6423,
                "line_11_flow": {
                    "p_from_mw": -322.6527,
                    "p_to_mw": 323.3765
                }
            }
        },
        {
            "id": "Q5",
            "category": "Optimal Power Flow",
            "query": "Run DC OPF on the Texas 2k grid and return the optimal generation profile and total cost.",
            "server_use": [
                "OPF"
            ],
            "expected_output": {
                "total_generation_cost": 184290.887,
                "generation_profile_mw": {
                    "260": 1100,
                    "158": 1100,
                    "159": 1100,
                    "412": 600,
                    "428": 525
                }
            }
        },
        {
            "id": "Q6",
            "category": "Contingency",
            "query": "For the IEEE 118-bus system, perform an N-1 contingency analysis to evaluate the impact of disconnecting line 171. Summarize the limits violation.",
            "server_use": [
                "Contingency"
            ],
            "expected_output": {
                "voltage_violation": {
                    "bus": 117,
                    "vm_pu": 0.929,
                    "vmin_pu": 0.94,
