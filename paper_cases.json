{
    "benchmark_queries": [
        {
            "id": "Q1",
            "category": "Grid dataset retrieval",
            "query": "Load the IEEE-39 bus system. What are the connected buses for line 11? What are the voltage limits of bus 3?",
            "server_use": [
                "Retrieval"
            ],
            "expected_output": {
                "line_11": {
                    "from_bus": 5,
                    "to_bus": 10
                },
                "bus_3_voltage_limits": {
                    "vm_min_pu": 0.94,
                    "vm_max_pu": 1.06
                }
            }
        },
        {
            "id": "Q2",
            "category": "Documentation retrieval",
            "query": "In ERCOT operations, what is the maximum delay allowed for under-frequency relays serving load resources?",
            "server_use": [
                "Retrieval"
            ],
            "expected_output": {
                "max_delay_cycles": 20,
                "citation": "ERCOT Nodal Operating Guides, Section 2.3.1.2, paragraph (6)(a)"
            }
        },
        {
            "id": "Q3",
            "category": "Topology",
            "query": "For the IEEE 39-bus system, what is the shortest path between bus 1 and bus 10?",
            "server_use": [
                "Topology"
            ],
            "expected_output": {
                "path_bus_indices": [
                    1,
                    2,
                    3,
                    4,
                    5,
                    10
